{
  "name": "@kanava/editor-react",
  "version": "0.1.0-beta.1",
  "description": "React UI components for Kanava Editor — toolbar, format bar, block picker, context menu, and editor hooks.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "editor",
    "react",
    "prosemirror",
    "toolbar",
    "format-bar",
    "block-picker",
    "wysiwyg",
    "kanava"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kanakalanjani/kanava-editor.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Kanakalanjani/kanava-editor#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "agents": {
    "skills": [
      {
        "name": "kanava-react",
        "path": "./skills/kanava-react"
      },
      {
        "name": "kanava-react-custom",
        "path": "./skills/kanava-react-custom"
      }
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@kanava/editor": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@kanava/editor": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}